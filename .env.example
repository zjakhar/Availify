# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=

# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=

# Twilio SMS credentials (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# How often to check inventory (cron expression, default: every 5 minutes)
CHECK_INTERVAL=*/5 * * * *

# Path to watchlist file (default: ./watchlist.json)
WATCHLIST_PATH=./watchlist.json
